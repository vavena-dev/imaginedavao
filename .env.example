HOST=127.0.0.1
PORT=8080

# Toggle Supabase-backed CMS/booking store
CMS_BACKEND=supabase

# Supabase project configuration
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional: direct database URL for migration tooling
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@YOUR_POOLER_HOST:6543/postgres?sslmode=require

# Legacy admin access token (optional when using Supabase admin role)
ADMIN_TOKEN=YOUR_ADMIN_TOKEN

# Optional external RAG service URL for chat responses
RAG_API_URL=
